"role.objector.name" : "异议者"
"role.objector.blurb" : "我对本次会议的结果不满意"
"role.objector.doc" : "<b>本职业有bug。</b><br>你可以在会议上使用<b>异议</b>技能。<br>如果使用了异议，那么本轮所有人的投票将被转换为弃票"
"options.role.objector.detail" : "异议者可以使用技能让本轮会议投票无效<br><b>这是半糖送给你的礼物之一！</b>"
"role.objector.ability.title" : "<b>固有能力【异议裁定】</b>"
"role.objector.ability.main" : "你可以使用异议来让本轮会议所有人的投票结果更改为弃票。<br>如果你反悔了，你可以在投票结果出现前取消异议。"
"role.objector.doc.objection" : "<b>异议</b><br>在会议阶段时进行异议。最多可用<b><color=#00ffff>%USES%次</color>。</b>"
"role.objector.doc.cancel" : "<b>取消异议</b><br>可以取消异议。"
"role.objector.tips" : "<b>·不建议非匿名投票下开启本职业</b>"
"options.role.objector.uses" : "异议最大使用次数"
"objector.ui.uses" : "剩余异议次数：%LEFTUSES%"



"role.owl.name" : "猫头鹰"
"role.owl.short" : "鹰"
"role.owl.blurb" : "深夜的人为我所用！"
"role.owl.doc" : "你可以使用催眠来催眠一个人。<br>被催眠者会获得一次击杀机会，并且计算为伪装者阵营。<br>被催眠者击杀一人后回归正常。如果不击杀的时间超过了<b><color=#00ffff>%DUR%秒</color></b>，<b>被催眠者自杀。</b>"
"options.role.owl.detail" : "猫头鹰可以催眠他人。<br><b>这是半糖送给你的礼物之一！</b>"
"role.owl.ability.title" : "<b>固有能力【催眠】</b>"
"role.owl.ability.main" : ""
"role.owl.tips" : "<b>·如果使用了噬魂，你会瞬移到被催眠者身旁来击杀他，而不是无声无息地让被催眠者自杀。</b>"
"options.role.owl.cooldown" : "催眠冷却"
"options.role.owl.maxUses" : "最大催眠次数"
"options.role.owl.duration" : "被催眠者自杀时限"
"options.role.owl.privateChat" : "私密频道"
"options.role.owl.soulEatCooldown" : "噬魂冷却"
