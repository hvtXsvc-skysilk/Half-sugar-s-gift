"achievement.restorer.challenge.all.title" : "その場にいる全員を還元する"
"achievement.restorer.challenge.all.cond" : "ヒント：5人以内での達成を推奨"
"achievement.restorer.challenge.all.goal" : "全員の職業を還元する"


"achievement.restorer.challenge.unused.title" : "何か忘れてる？"
"achievement.restorer.challenge.unused.cond" : ""
"achievement.restorer.challenge.unused.goal" : "1ゲーム中一度も還元を使わない"


"achievement.restorer.challenge.jesterWin.title" : "天からの歓喜！"
"achievement.restorer.challenge.jesterWin.cond" : "ヒント：追放する前に結果を考えてね"
"achievement.restorer.challenge.jesterWin.goal" : "還元者に還元された道化師を追放する"
"achievement.restorer.challenge.jesterWin.splitted.0" : "天からの"
"achievement.restorer.challenge.jesterWin.splitted.1" : "失敗"
"achievement.restorer.challenge.jesterWin.splitted.2" : "陽気な"










"role.objector.name" : "異議者"
"role.objector.blurb" : "私は今回の会議結果に納得していません"
"role.objector.doc" : "<b>この職業にはバグがあります。</b><br>会議で<b>異議</b>スキルを使用できます。<br>異議を使用すると、そのラウンドの全員の投票は棄権票に変換されます"
"options.role.objector.detail" : "異議者はスキルで今回の会議の投票を無効にできる<br><b>これは Half Sugar からのプレゼントの一つです！</b>"
"role.objector.ability.title" : "<b>固有アビリティ【異議裁定】</b>"
"role.objector.ability.main" : "異議を使って、そのラウンドの会議における全員の投票結果を棄権に変更できます。<br>後悔した場合、投票結果が出る前に異議を取り消せます。"
"role.objector.doc.objection" : "<b>異議</b><br>会議フェーズで異議を申し立てる。最大<b><color=#00ffff>%USES%回</color></b>使用可能。"
"role.objector.doc.cancel" : "<b>異議取消</b><br>異議を取り消すことができる。"
"role.objector.tips" : "<b>·匿名投票でない場合はこの職業の使用を推奨しません</b>"
"options.role.objector.uses" : "異議の最大使用回数"
"objector.ui.uses" : "残り異議回数：%LEFTUSES%"



"role.owl.name" : "フクロウ"
"role.owl.short" : "鷹"
"role.owl.blurb" : "深夜の者が私のために動く！"
"role.owl.doc" : "催眠を使って一人を催眠にかけられます。<br>催眠された者は1回のキルチャンスを得て、インポスター陣営としてカウントされます。<br>催眠された者が1人キルすると正常に戻ります。キルしない時間が<b><color=#00ffff>%DUR%秒</color></b>を超えると、<b>催眠された者は自殺します。</b>"
"options.role.owl.detail" : "フクロウは他人を催眠できます。<br><b>これは Half Sugar からのプレゼントの一つです！</b>"
"role.owl.ability.title" : "<b>固有アビリティ【催眠】</b>"
"role.owl.ability.main" : ""
"role.owl.tips" : "<b>·噬魂を使用すると、催眠された者のそばに瞬間移動してその者をキルします。催眠者が静かに自殺するのではありません。</b>"
"options.role.owl.cooldown" : "催眠クールダウン"
"options.role.owl.maxUses" : "最大催眠回数"
"options.role.owl.duration" : "催眠者自殺制限時間"
"options.role.owl.privateChat" : "プライベートチャット"
"options.role.owl.soulEatCooldown" : "噬魂クールダウン"
"button.label.owl.hypnotize" : "催眠"
"button.label.owl.soulEat" : "噬魂"
"button.label.owl.soulEatMeeting" : "噬魂"
"role.owl.doc.hypnotize" : "<b>催眠</b><br>一人を催眠する。最大<b><color=#00ffff>%MAXUSES%</color></b>回。"
"role.owl.doc.soulEat" : "<b>噬魂</b><br>催眠された者を即死させる。"
"owl.chatName" : "フクロウ"



#中立

"role.Havenger.blurb" : "目には目を、命には命を"
"role.Havenger.doc" : "<b>この職業にはバグがあります</b><br>フリーフェイズ中にキルされた場合、死体が消え、次のラウンドで尋仇状態になります。<br>その間、会議は禁止され、全員 VENT 禁止。<br>間違ってキルすると、尋仇者とキルされた者が死亡、時間切れなら尋仇者が死亡、正しくキルできれば尋仇者が勝利します。"
"role.Havenger.name" : "尋仇者"
"role.Havenger.tips" : "·あなたの尋仇キル回数は一度だけです。"
"options.role.Havenger.detail" : "尋仇者は死亡後、殺害者に復讐しなければならない<br><b>これは Half Sugar からのプレゼントの一つです！</b>"
"role.Havenger.short" : "尋"
"options.role.Havenger.revengeDuration" : "尋仇持続時間"
"teams.Havenger" : "尋仇者"
"HavengerWin" : "尋仇者の勝利"
"button.label.Havenger.kill" : "復讐"

"achievement.avenger.common.revenge.title" : "血の報い"
"achievement.avenger.common.revenge.goal" : "殺害者をキルする"
"achievement.avenger.common.revenge.cond" : ""

"achievement.avenger.common.wrongKill.title" : "無実の者を殺す"
"achievement.avenger.common.wrongKill.goal" : "尋仇フェーズで殺害者以外をキルする"
"achievement.avenger.common.wrongKill.cond" : ""

"achievement.avenger.common.timeout.title" : "魂の消失"
"achievement.avenger.common.timeout.goal" : "尋仇時間が終了し、誰もキルしていない"
"achievement.avenger.common.timeout.cond" : ""





"role.imagination.name" : "想像力"
"role.imagination.short" : "想"
"role.imagination.blurb" : "豊かな想像"
"role.imagination.doc" : "最後まで生き残り他人の勝利を奪う<br>各ラウンドで職業を一つ想像し、そのスキルを得る。"
"teams.imagination" : "想像力"
"options.role.imagination.candidateCount" : "ラウンドごとに想像できる職業の数"
"options.role.imagination.roleFilter" : "想像可能な職業"
"options.role.imagination.detail" : "想像力はラウンドごとに職業を一つ想像し、その特性を得る<br>最後まで生き残り勝利を奪う。<br><b>これは Half Sugar からのプレゼントの一つです！</b>"
"role.imagination.ability.title" : "<b>固有アビリティ【想像力抜群】</b>"
"role.imagination.ability.main" : "各ラウンドの会議終了後またはゲーム開始時に職業を一つ選び、その能力を得られます。<br>そのラウンド終了後、再び職業を選ぶ必要があります。"
"role.imagination.doc.skill" : "<b>想像</b><br>ラウンドごとに自動使用、職業を選びその能力を得る。"
"role.imagination.tips" : "<b>·特定の職業は選択してもそのスキルを持てません。</b><br><b>·勝利を奪うことができます。</b>"

"role.imagination.prefix" : "想像の%ROLE%"
"role.imagination.select" : "想像する職業を選んでください（選択後、このウィンドウを手動で閉じてください）"

"role.spirit.name" : "「霊」"
"role.spirit.short" : "霊"
"role.spirit.blurb" : "霊は生まれ、砕け、大業を託す。霊は連なり、霊はまた霊を砕く。尽きることなし。"
"role.spirit.doc" : "霊撃を使って選択した者を自殺させることができます。<br><b>還霊</b>を使って他者を霊にし、自身は砕霊になります。"
"options.role.spirit.detail" : "他人を霊に変え、共に勝利する<br><b>これは Half Sugar からのプレゼントの一つです！</b>"
"role.spirit.ability.title" : "<b>固有アビリティ【霊焔】</b>"
"role.spirit.ability.main" : "特殊なキル能力を持ち、選択した者を直接自殺させることができます。回数はホスト設定に依存。<br>キル回数を使い切ると還霊スキルがアンロックされます。<br>誰かに使うと、その人を霊にし、あなたは砕霊になります。<br>砕霊がキルできるかどうか、キル回数はホスト設定に依存。<br>霊が死亡すると、すべての砕霊も連鎖死亡します。<br>砕霊と霊には、霊陣営のみが見える名前の後の}{マークがあります。"
"role.spirit.doc.sb" : "<b>還霊</b><br>他者を霊に変え、自身は砕霊になる"
"options.role.spirit.KillCoolDown" : "キルクールタイム"
"options.role.spirit.KillMaxUses" : "最大キル回数"
"options.role.spirit.SoulBack" : "還霊使用可能"
"button.label.spirit.kill" : "霊撃"
"button.label.spirit.sb" : "還霊"

"role.brokenspirit.name" : "「砕霊」"
"role.brokenspirit.short" : "砕"
"role.brokenspirit.blurb" : "壊れかけた「魂」"
"role.brokenspirit.doc" : "砕霊は霊が還霊を使った後に生まれる役職で、通常のキルスキルを持ち、回数はホスト設定によります。<br>霊が死亡すると、すべての砕霊が死亡します。<br>霊と砕霊の名前の後には、この陣営のみが見られる}{マークがあります。"
"options.role.brokenspirit.detail" : "砕霊は霊が還霊を使用した後に生まれる役職です。<br><b>これは Half Sugar からのプレゼントの一つです！</b>"



