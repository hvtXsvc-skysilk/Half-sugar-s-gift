"role.HNoiseMaker.name" : "大声"
"role.HNoiseMaker.generalBlurb" : "死んだら叫ぶ"
"role.HNoiseMaker.doc" : "大声が死亡したとき、死亡地点でアラートと矢印が表示され、「ワオ」と鳴きます。<br><b>この職業は大声の追加バージョンです。</b>"
"options.role.HNoiseMaker.noiseDuration" : "アラート持続時間"
"options.role.HNoiseMaker.detail" : "大声がキルされると警告音が鳴る。<br>おとりと一緒にプレイするのが楽しみ。<br><b>これは Half Sugar からのプレゼントの一つです！</b>"



"role.keymaster.name" : "キーマスター"
"role.keymaster.generalBlurb" : "開けゴマ"
"role.keymaster.doc" : "<b>SKELD</b>と<b>MIRAHQ</b>以外のすべてのドアを直接開けることができます。"
"options.role.keymaster.detail" : "ドアを直接開けられる"
"options.modifier.keymaster.cooldown" : "ドア開閉クールダウン"
"button.label.keymaster.open" : "ドアを開ける"


"role.hypnotized.name" : "催眠された者"
